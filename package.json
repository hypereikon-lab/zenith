{
  "name": "zenith",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "typecheck:engine": "tsc -p tsconfig.engine.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "svelte-kit sync && tsc --noEmit && npm run typecheck:engine",
    "prepare": "svelte-kit sync || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.64.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.6.2",
    "@webgpu/types": "^0.1.70",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.130.0",
    "mediabunny": "^1.44.2",
    "zod": "^4.4.3"
  }
}
